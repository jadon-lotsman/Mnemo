{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=./dev.db"
  },
  "Jwt": {
    "Key": "---",
    "Issuer": "Mnemo",
    "Audience": "Mnemo"
  },
  "EnrichmentOptions": {
    "IsEnabled": false,
    "BatchSize": 5,
    "BatchDelaySeconds": 150,
    "RequestDelayMilliseconds": 800,
    "StuckProcessingTimeoutMinutes": 10
  },
  "RepetitionOptions": {
    "RepetitionTaskCount": 10,
    "OptionsDistractorCount": 3
  },
  "SM2Options": {
    "MinEF": 1.3,
    "MaxEF": 3.2,
    "InitEF": 2.5,

    "MinInterval": 1,
    "MaxInterval": 365,
    "FirstIntervalDays": 1,
    "SecondIntervalDays": 3,

    "MinQuality": 0,
    "MaxQuality": 5,
    "PassingQuality": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "System.Net.Http.HttpClient": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": false,
        "TimestampFormat": "dd.MM.yy HH:mm:ss:ff ",
        "UseUtcTimestamp": true,
        "IncludeScopes": false
      }
    }
  }
}
