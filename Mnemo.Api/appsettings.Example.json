{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=Data/app.db"
  },
  "Jwt": {
    "Key": "---",
    "Issuer": "Mnemo",
    "Audience": "Mnemo"
  },
  "Enrichment": {
    "IsEnabled": true,
    "BatchSize": 5,
    "BatchDelaySeconds": 150,
    "RequestDelayMilliseconds": 800,
    "StuckProcessingTimeoutMinutes": 10
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "System.Net.Http.HttpClient": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "dd.MM.yy HH:mm:ss:ff ",
        "UseUtcTimestamp": true,
        "IncludeScopes": false
      }
    }
  }
}
